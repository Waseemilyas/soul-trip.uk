# soul-trip.uk — credential template (safe to commit)
# Copy to `.env` and fill in. The real .env is gitignored.

# --- Formspree (CLI project) ---
FORMSPREE_PROJECT_ID=
FORMSPREE_DEPLOY_KEY=

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=soul-trip.uk
# Scoped API token (Zone:Read + DNS:Edit on soul-trip.uk).
# Mint at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
